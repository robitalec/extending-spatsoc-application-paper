digraph {
  graph [rankdir=TB]
  fread -> group_times
  group_times -> {group_pts; edge_dist; calc_az_sequential}

  group_pts -> group_centroid
  group_centroid -> {dist_to_group_centroid; az_to_group_centroid}

  group_pts -> calc_dir_corr_delay
  edge_dist -> calc_dir_corr_delay

  {calc_az_sequential; group_centroid} -> position_within_group -> {dist_to_leader; az_to_leader}
