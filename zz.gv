  calc_az_sequential -> directional_alignment

  group_times -> interindividual_direction -> behavioural_zones

	{rank=same; dist_to_leader; dist_to_group_centroid; az_to_leader; az_to_group_centroid; calc_dir_corr_delay; polarization; directional_alignment; interindividual_direction;}

}