@article{Peignier_2019,
  type = {Article},
  title = {Space Use and Social Association in a Gregarious Ungulate: {{Testing}} the Conspecific Attraction and Resource Dispersion Hypotheses},
  author = {Peignier, Melissa and Webber, Quinn M. R. and Koen, Erin L. and Laforge, Michel P. and Robitaille, Alec L. and Vander Wal, Eric},
  year = 2019,
  month = may,
  journal = {ECOLOGY AND EVOLUTION},
  volume = {9},
  number = {9},
  pages = {5133--5145},
  publisher = {WILEY},
  address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
  issn = {2045-7758},
  doi = {10.1002/ece3.5071},
  abstract = {Animals use a variety of proximate cues to assess habitat quality when resources vary spatiotemporally. Two nonmutually exclusive strategies to assess habitat quality involve either direct assessment of landscape features or observation of social cues from conspecifics as a form of information transfer about forage resources. The conspecific attraction hypothesis proposes that individual space use is dependent on the distribution of conspecifics rather than the location of resource patches, whereas the resource dispersion hypothesis proposes that individual space use and social association are driven by the abundance and distribution of resources. We tested the conspecific attraction and the resource dispersion hypotheses as two nonmutually exclusive hypotheses explaining social association and of adult female caribou (Rangifer tarandus). We used location data from GPS collars to estimate interannual site fidelity and networks representing home range overlap and social associations among individual caribou. We found that home range overlap and social associations were correlated with resource distribution in summer and conspecific attraction in winter. In summer, when resources were distributed relatively homogeneously, interannual site fidelity was high and home range overlap and social associations were low. Conversely, in winter when resources were distributed relatively heterogeneously, interannual site fidelity was low and home range overlap and social associations were high. As access to resources changes across seasons, caribou appear to alter social behavior and space use. In summer, caribou may use cues associated with the distribution of forage, and in winter caribou may use cues from conspecifics to access forage. Our results have broad implications for our understanding of caribou socioecology, suggesting that caribou use season-specific strategies to locate forage. Caribou populations continue to decline globally, and our finding that conspecific attraction is likely related to access to forage suggests that further fragmentation of caribou habitat could limit social association among caribou, particularly in winter when access to resources may be limited.},
  affiliation = {Webber, QMR (Corresponding Author), Mem Univ Newfoundland, Cognit \& Behav Ecol Interdisciplinary Program, St John, NF, Canada. Peignier, Melissa; Koen, Erin L.; Laforge, Michel P.; Robitaille, Alec L.; Vander Wal, Eric, Mem Univ Newfoundland, Dept Biol, St John, NF, Canada. Webber, Quinn M. R.; Vander Wal, Eric, Mem Univ Newfoundland, Cognit \& Behav Ecol Interdisciplinary Program, St John, NF, Canada.},
  affiliations = {Memorial University Newfoundland; Memorial University Newfoundland},
  author-email = {webber.quinn@gmail.com},
  da = {2023-05-14},
  doc-delivery-number = {HX7KR},
  funding-acknowledgement = {National Science and Engineering Council of Canada},
  funding-text = {National Science and Engineering Council of Canada},
  journal-iso = {Ecol. Evol.},
  keywords-plus = {CARIBOU RANGIFER-TARANDUS; HOME-RANGE OVERLAP; SITE FIDELITY; WOODLAND CARIBOU; HABITAT SELECTION; TEMPORAL VARIATION; PREDATION RISK; ECOLOGY; EXPLAIN; INFORMATION},
  langid = {english},
  number-of-cited-references = {75},
  oa = {Green Published, gold},
