@article{Weesner_2023,
  title = {Interaction Rules Guiding Collective Behaviour in Echolocating Bats},
  author = {Weesner, A. and Bentley, I. and Fullerton, J. and Kloepper, L.},
  year = 2023,
  journal = {Anim. Behav.},
  publisher = {Academic Press},
  doi = {10.1016/j.anbehav.2023.09.009},
  abstract = {Collective behaviour in animals that move in three dimensions can often be explained by simple interaction rules. For animals that rely on active sensing, such as echolocating bats, sensing and following conspecifics may be challenging in dense groups, yet the flight behaviour of individuals in dense bat groups remains poorly studied. Here, we investigate the rules guiding collective behaviour in a species of echolocating bat (Tadarida brasiliensis) during evening exodus from a cave. Using high-resolution thermal imagery, we tracked the flight coordination and wing beat phase of bats flying together. We found that bats aligned and responded strongest to individuals flying in front of them. Additionally, they responded to conspecifics much slower than predicted if they were using an intermittent sensorimotor strategy to sense leader position and movement. \copyright{} 2023 The Association for the Study of Animal Behaviour}
}

@article{Wilson_2017,
  title = {Good Enough Practices in Scientific Computing},
  author = {Wilson, Greg and Bryan, Jennifer and Cranston, Karen and Kitzes, Justin and Nederbragt, Lex and Teal, Tracy K.},
  year = 2017,
  month = jun,
  journal = {PLOS Computational Biology},
  volume = {13},
  number = {6},
  pages = {e1005510},
  publisher = {Public Library of Science},
  issn = {1553-7358},
  doi = {10.1371/journal.pcbi.1005510},
  urldate = {2025-08-07},
  abstract = {Author summary Computers are now essential in all branches of science, but most researchers are never taught the equivalent of basic lab skills for research computing. As a result, data can get lost, analyses can take much longer than necessary, and researchers are limited in how effectively they can work with software and data. Computing workflows need to follow the same practices as lab projects and notebooks, with organized data, documented steps, and the project structured for reproducibility, but researchers new to computing often don't know where to start. This paper presents a set of good computing practices that every researcher can adopt, regardless of their current level of computational skill. These practices, which encompass data management, programming, collaborating with colleagues, organizing projects, tracking work, and writing manuscripts, are drawn from a wide variety of published sources from our daily lives and from our work with volunteer organizations that have delivered workshops to over 11,000 people since 2010.},
  langid = {english},
  keywords = {Computer software,Control systems,Data management,Metadata,Programming languages,Reproducibility,Software tools,Source code},
  file = {/home/alecr/Zotero/storage/YRQKSR2U/Wilson et al. - 2017 - Good enough practices in scientific computing.pdf}
}
